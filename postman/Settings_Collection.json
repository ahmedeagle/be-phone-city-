{
    "info": {
        "_postman_id": "settings-collection-001",
        "name": "Settings API",
        "description": "Postman collection for Settings API endpoints. All endpoints are public and don't require authentication. Settings are managed as a singleton (single record with id=1).",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Settings",
            "item": [
                {
                    "name": "Get All Settings",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Accept-Language",
                                "value": "en",
                                "type": "text",
                                "description": "Language code: en or ar (optional, defaults to en)"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/settings",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "settings"]
                        },
                        "description": "Get all settings including website information, shipping/tax settings, points settings, bank account details, and product sections settings.\n\n**Response includes:**\n- Website information (title, logo)\n- Shipping and tax settings\n- Points/rewards settings\n- Bank account details\n- Product sections settings (new arrivals, featured)"
                    },
                    "response": [
                        {
                            "name": "Success Response",
                            "originalRequest": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/api/v1/settings",
                                    "host": ["{{base_url}}"],
                                    "path": ["api", "v1", "settings"]
                                }
                            },
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "cookie": [],
                            "body": "{\n    \"success\": true,\n    \"message\": \"Settings fetched successfully\",\n    \"data\": {\n        \"website_title_en\": \"City Phone\",\n        \"website_title_ar\": \"سيتي فون\",\n        \"logo\": \"http://localhost:8000/storage/settings/logo.png\",\n        \"free_shipping_threshold\": 100.00,\n        \"tax_percentage\": 15.00,\n        \"points_days_expired\": 365,\n        \"point_value\": 1.00,\n        \"bank_name\": \"Al Rajhi Bank\",\n        \"account_holder\": \"City Phone Company\",\n        \"account_number\": \"1234567890\",\n        \"iban\": \"SA1234567890123456789012\",\n        \"swift_code\": \"RJHISARI\",\n        \"branch\": \"Main Branch\",\n        \"bank_instructions\": \"Please include order number in transfer notes\",\n        \"show_new_arrivals_section\": true,\n        \"show_featured_section\": true,\n        \"new_arrivals_count\": 10,\n        \"featured_count\": 10\n    }\n}"
                        }
                    ]
                },
                {
                    "name": "Get Specific Setting by Key",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/settings/website_title_en",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "settings", "website_title_en"]
                        },
                        "description": "Get a specific setting value by its key.\n\n**Available keys:**\n- `website_title_en`, `website_title_ar`\n- `free_shipping_threshold`, `tax_percentage`\n- `points_days_expired`, `point_value`\n- `bank_name`, `account_holder`, `account_number`, `iban`, `swift_code`, `branch`, `bank_instructions`\n- `show_new_arrivals_section`, `show_featured_section`, `new_arrivals_count`, `featured_count`\n\n**Example keys:**\n- `website_title_en`\n- `tax_percentage`\n- `point_value`"
                    },
                    "response": [
                        {
                            "name": "Success Response",
                            "originalRequest": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/api/v1/settings/website_title_en",
                                    "host": ["{{base_url}}"],
                                    "path": ["api", "v1", "settings", "website_title_en"]
                                }
                            },
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "cookie": [],
                            "body": "{\n    \"success\": true,\n    \"message\": \"Setting fetched successfully\",\n    \"data\": {\n        \"key\": \"website_title_en\",\n        \"value\": \"City Phone\"\n    }\n}"
                        },
                        {
                            "name": "Not Found",
                            "originalRequest": {
                                "method": "GET",
                                "header": [],
                                "url": {
                                    "raw": "{{base_url}}/api/v1/settings/invalid_key",
                                    "host": ["{{base_url}}"],
                                    "path": ["api", "v1", "settings", "invalid_key"]
                                }
                            },
                            "status": "Not Found",
                            "code": 404,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "cookie": [],
                            "body": "{\n    \"success\": false,\n    \"message\": \"Setting not found\",\n    \"data\": null\n}"
                        }
                    ]
                }
            ],
            "description": "Get all settings or a specific setting by key"
        },
