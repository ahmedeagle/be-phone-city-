                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"code\": \"FIRST10\"\n}",
                    "options": {
                        "raw": {
                            "language": "json"
                        }
                    }
                },
                "url": {
                    "raw": "{{base_url}}/api/v1/discounts/check-code",
                    "host": ["{{base_url}}"],
                    "path": ["api", "v1", "discounts", "check-code"]
                },
                "description": "Validate a discount code. Checks if the code is:\n- Exists in the database\n- Status is active\n- Current date is within the valid date range (between start and end dates)\n\n**Authentication:** Required (Bearer token)\n\n**Request Body:**\n- `code` (string, required, max 255): The discount code to validate\n\n**Response (Success):**\nReturns the discount details if valid\n\n**Response (Error):**\n- 404: Discount code not found\n- 400: Discount code is not active or expired"
            },
            "response": [
                {
                    "name": "Valid Code - Success",
                    "originalRequest": {
