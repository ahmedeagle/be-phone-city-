{
    "info": {
        "_postman_id": "discounts-collection-001",
        "name": "Discounts API",
        "description": "Postman/Apidog collection for Discounts API endpoints. All endpoints require authentication (auth:sanctum). Note: Authentication token should be inherited from main auth folder in Apidog.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Get All Discounts",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Accept-Language",
                        "value": "en",
                        "type": "text",
                        "description": "Language code: en or ar (optional, defaults to en)"
                    }
                ],
                "url": {
                    "raw": "{{base_url}}/api/v1/discounts?type=&search=&per_page=15",
                    "host": ["{{base_url}}"],
                    "path": ["api", "v1", "discounts"],
                    "query": [
                        {
                            "key": "type",
                            "value": "",
                            "description": "Filter by discount type: percentage or fixed (optional)",
                            "disabled": true
                        },
                        {
                            "key": "search",
                            "value": "",
                            "description": "Search discounts by code (optional)",
                            "disabled": true
                        },
                        {
                            "key": "per_page",
                            "value": "15",
                            "description": "Number of items per page (optional, default: 15)",
                            "disabled": true
                        }
                    ]
                },
                "description": "Get all active discounts. Only returns discounts that are:\n- Status is active (status = true)\n- Current date is between start and end dates\n\n**Authentication:** Required (Bearer token)\n\n**Query Parameters (all optional):**\n- `type`: Filter by discount type (`percentage` or `fixed`)\n- `search`: Search discounts by code\n- `per_page`: Number of items per page (default: 15)\n\n**Response includes:**\n- Paginated list of active discounts\n- Each discount includes: id, code, status, type, value, description, start/end dates, condition"
            },
            "response": [
                {
                    "name": "Success Response",
                    "originalRequest": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/v1/discounts",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "discounts"]
                        }
                    },
                    "status": "OK",
                    "code": 200,
                    "_postman_previewlanguage": "json",
                    "header": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        }
                    ],
                    "cookie": [],
                    "body": "{\n    \"success\": true,\n    \"message\": \"Discounts fetched successfully\",\n    \"data\": [\n        {\n            \"id\": 1,\n            \"code\": \"FIRST10\",\n            \"status\": true,\n            \"type\": \"percentage\",\n            \"value\": 10.0,\n            \"description\": \"Get 10% off on your first order!\",\n            \"start\": \"2025-12-06T12:00:00.000000Z\",\n            \"end\": \"2025-06-06T12:00:00.000000Z\",\n            \"condition\": {\n                \"type\": \"first_order\"\n            }\n        },\n        {\n            \"id\": 2,\n            \"code\": \"SAVE20\",\n            \"status\": true,\n            \"type\": \"percentage\",\n            \"value\": 20.0,\n            \"description\": \"Save 20% on orders over 100 SAR\",\n            \"start\": \"2025-12-06T12:00:00.000000Z\",\n            \"end\": \"2025-03-06T12:00:00.000000Z\",\n            \"condition\": {\n                \"type\": \"min_amount\",\n                \"value\": 100\n            }\n        },\n        {\n            \"id\": 5,\n            \"code\": \"FIXED50\",\n            \"status\": true,\n            \"type\": \"fixed\",\n            \"value\": 50.0,\n            \"description\": \"Get 50 SAR off on orders over 200 SAR\",\n            \"start\": \"2025-12-06T12:00:00.000000Z\",\n            \"end\": \"2025-02-06T12:00:00.000000Z\",\n            \"condition\": {\n                \"type\": \"min_amount\",\n                \"value\": 200\n            }\n        }\n    ],\n    \"pagination\": {\n        \"current_page\": 1,\n        \"per_page\": 15,\n        \"total\": 3,\n        \"last_page\": 1,\n        \"from\": 1,\n        \"to\": 3\n    }\n}"
                },
                {
                    "name": "Unauthenticated",
                    "originalRequest": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/discounts",
                            "host": ["{{base_url}}"],
                            "path": ["api", "v1", "discounts"]
                        }
                    },
                    "status": "Unauthorized",
                    "code": 401,
                    "_postman_previewlanguage": "json",
