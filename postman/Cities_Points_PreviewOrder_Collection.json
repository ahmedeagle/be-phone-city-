                            "body": "{\n    \"success\": true,\n    \"message\": \"Order preview calculated successfully\",\n    \"data\": {\n        \"items\": [\n            {\n                \"id\": 1,\n                \"product\": {\n                    \"id\": 1,\n                    \"slug\": \"iphone-15-pro\",\n                    \"name\": \"iPhone 15 Pro\",\n                    \"name_en\": \"iPhone 15 Pro\",\n                    \"name_ar\": \"آيفون 15 برو\",\n                    \"main_image\": \"http://localhost:8000/storage/products/iphone15pro.jpg\",\n                    \"stock_status\": \"in_stock\",\n                    \"quantity_available\": 10\n                },\n                \"product_option\": null,\n                \"price\": \"500.00\",\n                \"quantity\": 1,\n                \"total\": \"500.00\"\n            }\n        ],\n        \"summary\": {\n            \"subtotal\": \"500.00\",\n            \"discount\": \"50.00\",\n            \"discount_code\": \"FIRST10\",\n            \"discount_info\": {\n                \"id\": 1,\n                \"code\": \"FIRST10\",\n                \"type\": \"percentage\",\n                \"value\": 10.0,\n                \"discount_amount\": \"50.00\"\n            },\n            \"shipping\": \"25.00\",\n            \"shipping_info\": {\n                \"city\": {\n                    \"id\": 1,\n                    \"slug\": \"riyadh\",\n                    \"name\": \"Riyadh\",\n                    \"name_en\": \"Riyadh\",\n                    \"name_ar\": \"الرياض\",\n                    \"shipping_fee\": \"25.00\"\n                },\n                \"location\": {\n                    \"id\": 1,\n                    \"first_name\": \"John\",\n                    \"last_name\": \"Doe\",\n                    \"country\": \"Saudi Arabia\",\n                    \"city\": \"Riyadh\",\n                    \"street_address\": \"123 Main St\",\n                    \"phone\": \"+9665012345